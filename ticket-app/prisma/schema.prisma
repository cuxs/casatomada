generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sale {
  id          String    @id @default(uuid())
  buyerName   String
  price       Int
  qrToken     String    @unique
  codeWord    String    @unique
  ticketCount Int       @default(1)
  used        Boolean   @default(false)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  guardarropaChecks GuardarropaCheck[]

  @@index([createdAt])
}

model GuardarropaCheck {
  id          String    @id @default(uuid())
  saleId      String
  sale        Sale      @relation(fields: [saleId], references: [id])
  itemCount   Int
  description String    @default("")
  createdAt   DateTime  @default(now())
  retrievedAt DateTime?

  @@index([saleId, retrievedAt])
}

model RidePost {
  id         String   @id @default(uuid())
  authorName String
  content    String
  phone      String?
  createdAt  DateTime @default(now())
}
