generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sale {
  id          String    @id @default(uuid())
  buyerName   String
  price       Int
  qrToken     String    @unique
  codeWord    String    @unique
  ticketCount Int       @default(1)
  used        Boolean   @default(false)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model RidePost {
  id         String        @id @default(uuid())
  authorName String
  content    String
  createdAt  DateTime      @default(now())
  comments   RideComment[]
}

model RideComment {
  id         String   @id @default(uuid())
  postId     String
  authorName String
  content    String
  createdAt  DateTime @default(now())
  post       RidePost @relation(fields: [postId], references: [id], onDelete: Cascade)
}
